{
  "name": "receitas-da-vo",
  "version": "0.1.0",
  "description": "Aplicação web Receitas da Vó para preservar memórias familiares por meio de receitas afetivas.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "npm run test:unit && npm run test:api && npm run test:smoke",
    "test:unit": "mocha \"tests/unit/**/*.test.js\" --exit",
    "test:api": "mocha \"tests/api/**/*.test.js\" --exit",
    "test:smoke": "mocha \"tests/smoke/**/*.test.js\" --exit",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open"
  },
  "keywords": [
    "receitas",
    "qa",
    "cypress",
    "supertest"
  ],
  "author": "Hugo Torquetti",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "cypress": "^13.17.0",
    "mocha": "^10.8.2",
    "supertest": "^7.0.0"
  }
}
